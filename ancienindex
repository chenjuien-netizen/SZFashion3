<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#f7f9fb" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta
      name="szfashion-pull-url"
      content="https://script.google.com/macros/s/AKfycbxh9qfvJxG-Jag6JqQY8PJoW8TEq_swG7boa72SFfCMXX6KPqF_XTQsa9XSoUq7iBqa7g/exec"
    />
    <meta
      name="szfashion-pull-url"
      content="https://script.google.com/macros/s/AKfycbxh9qfvJxG-Jag6JqQY8PJoW8TEq_swG7boa72SFfCMXX6KPqF_XTQsa9XSoUq7iBqa7g/exec"
    />
    <title>SZFASHION | Inventaire</title>
    <link rel="manifest" href="./manifest.webmanifest" />
    <link rel="icon" href="./icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="./icon.svg" />
    <link rel="stylesheet" href="./styles.css" />
    <script type="module" src="./app.js"></script>
  </head>
  <body>
    <div id="appShell" class="app-shell">
      <main class="app-main">
        <div class="top-shell">
          <header id="appHeader" class="app-header">
            <div class="header-title-wrap">
              <div>
                <h1 id="appTitle" class="app-title">SZFASHION</h1>
              </div>
            </div>
            <div class="header-actions">
              <button
                id="refreshButton"
                class="icon-button"
                type="button"
                aria-label="Rafraîchir l'inventaire"
              >
                Rafraîchir
              </button>
            </div>
          </header>

          <section id="searchSection" class="search-section">
            <label class="search-field" for="searchInput">
              <span class="search-label">Rechercher</span>
              <input
                id="searchInput"
                type="search"
                autocomplete="off"
                placeholder="Recherche référence..."
              />
            </label>
          </section>

          <section id="statusBar" class="status-bar" aria-live="polite">
            <div class="status-chip">
              <span class="status-label">Réseau</span>
              <span id="networkStatus" class="status-value">-</span>
            </div>
            <div class="status-chip">
              <span class="status-label">État</span>
              <span id="syncStatus" class="status-value">Chargement...</span>
            </div>
            <div class="status-chip">
              <span class="status-label">Maj</span>
              <span id="lastUpdated" class="status-value">-</span>
            </div>
            <div class="status-chip">
              <span class="status-label">Réfs</span>
              <span id="recordCount" class="status-value">0</span>
            </div>
          </section>
        </div>

        <section id="inventoryScroll" class="inventory-scroll">
          <ul id="inventoryList" class="inventory-list" aria-live="polite"></ul>
          <div id="emptyState" class="empty-state hidden">
            <p id="emptyTitle" class="empty-title">Chargement...</p>
            <p id="emptyMessage" class="empty-message"></p>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
