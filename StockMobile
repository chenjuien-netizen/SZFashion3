                  (isItemPending(itemId) ? '<span class="shrink-0 rounded border border-outline-variant/30 px-1 py-0.5 text-[8px] font-bold uppercase tracking-[0.14em] text-on-surface-variant">Sync</span>' : '') +
                '</div>' +
