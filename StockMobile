        }

        function splitPackNotation(value) {
          const parsed = parsePackNotation(getMainPackNotationFromState_({ packNotation: value }));
          return {
            sign: parsed.sign === "-" ? "-" : "+",
            count: parsed.count > 0 ? String(parsed.count) : ""
          };
        }

        function hasQuickEditAdvancedValues(form) {
