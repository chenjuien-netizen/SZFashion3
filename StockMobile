        function renderInventoryLoadingMarkup_() {
          return '<div class="flex flex-col gap-px bg-outline-variant/20">'
            + [0, 1, 2, 3, 4, 5].map(function() {
              return '<div class="bg-surface-container-lowest px-3 py-3">'
                + '<div class="h-3 w-24 animate-pulse bg-surface-container-high"></div>'
                + '<div class="mt-2 h-3 w-40 animate-pulse bg-surface-container-high"></div>'
                + '</div>';
