        function sanitizeIntegerInput(value) {
          if (value === "" || value == null) return "";
          const normalized = String(value).trim();
          if (!normalized) return "";
          const numeric = Number(normalized);
          if (!Number.isFinite(numeric) || numeric < 0) return "";
          return String(Math.trunc(numeric));
        }

        function sanitizeSign(value) {
          return value === "×" ? "×" : "+";
        }

        function sanitizeFractionText(value) {
          const normalized = String(value || "").trim().replace(/\s+/g, "");
          if (!normalized) return "";
          return /^(\d+)\/(\d+)$/.test(normalized) ? normalized : normalized;
        }

        function normalizePackNotation(value, strict) {
          const normalized = String(value || "").trim();
          if (!normalized) return "";
          const match = normalized.match(/^([+-])\s*(\d+)\s*包$/i);
          if (!match) {
            if (strict) return "";
            return normalized;
          }
          const count = Math.max(0, Math.trunc(Number(match[2]) || 0));
          if (!(count > 0)) return "";
          return match[1] + count + "包";
        }

        function normalizeTailRelativeNotation(value) {
          const normalized = String(value || "").trim().replace(/^TAIL:/i, "");
          if (!normalized) return "";
          const packNotation = normalizePackNotation(normalized, false);
          if (/^-\d+包$/.test(packNotation)) return packNotation;
          const fractionText = sanitizeFractionText(normalized);
          return parseFraction(fractionText) > 0 ? fractionText : "";
        }

        function splitCompositePackNotation(value) {
          const normalized = String(value || "").trim();
          if (!normalized) {
            return { tailNotation: "", mainNotation: "" };
          }
          const parts = normalized.split("|");
          let tailNotation = "";
          let mainNotation = "";
          parts.forEach(function(part) {
            const token = String(part || "").trim();
            if (!token) return;
            if (/^TAIL:/i.test(token)) {
              if (!tailNotation) tailNotation = normalizeTailRelativeNotation(token);
              return;
            }
            const packNotation = normalizePackNotation(token, false);
            if (!mainNotation && /^([+-])\d+包$/.test(packNotation)) {
              mainNotation = packNotation;
            }
          });
          return {
            tailNotation: tailNotation,
            mainNotation: mainNotation
          };
        }

        function buildCompositePackNotation(tailNotation, mainNotation) {
          const normalizedTail = normalizeTailRelativeNotation(tailNotation);
          const normalizedMain = normalizePackNotation(mainNotation, false);
          if (normalizedTail && normalizedMain) return "TAIL:" + normalizedTail + "|" + normalizedMain;
          if (normalizedTail) return "TAIL:" + normalizedTail;
          return /^([+-])\d+包$/.test(normalizedMain) ? normalizedMain : "";
        }

        function getTailNotationFromState_(stateModel) {
          return splitCompositePackNotation(stateModel && stateModel.packNotation).tailNotation;
        }

        function getMainPackNotationFromState_(stateModel) {
          return splitCompositePackNotation(stateModel && stateModel.packNotation).mainNotation;
        }

        function getTailActualPieces_(stateModel) {
          const tailBase = Math.max(0, Math.trunc(Number(stateModel && stateModel.tail) || 0));
          const tailNotation = getTailNotationFromState_(stateModel);
          if (!(tailBase > 0) || !tailNotation) return tailBase;
          if (/^-\d+包$/.test(tailNotation)) {
            const packMeta = parsePackNotation(tailNotation);
            const colisage = Math.max(0, Math.trunc(Number(stateModel && stateModel.colisage) || 0));
            return Math.max(0, tailBase - (packMeta.count * colisage));
          }
          const fractionValue = parseFraction(tailNotation);
          if (!(fractionValue > 0)) return tailBase;
          return Math.max(0, tailBase * fractionValue);
        }

        function buildTailRemainingFractionTextFromExit_(fractionText) {
          const normalized = sanitizeFractionText(fractionText);
          const match = normalized.match(/^(\d+)\/(\d+)$/);
          if (!match) return "";
          const numerator = Math.max(0, Math.trunc(Number(match[1]) || 0));
          const denominator = Math.max(0, Math.trunc(Number(match[2]) || 0));
          if (!(denominator > 0) || numerator <= 0 || numerator >= denominator) return "";
          const remainingNumerator = denominator - numerator;
          const divisor = gcd(remainingNumerator, denominator);
          return (remainingNumerator / divisor) + "/" + (denominator / divisor);
        }

        function buildTailDisplay_(stateModel) {
          const tailBase = Math.max(0, Math.trunc(Number(stateModel && stateModel.tail) || 0));
          if (!(tailBase > 0)) return "";
          const tailNotation = getTailNotationFromState_(stateModel);
