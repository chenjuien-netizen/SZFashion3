        function renderColumnLayoutMarkup(columns) {
          if (!columns.length) return "";
          return '<div class="flex items-start gap-px bg-outline-variant/20">' + columns.map(function(columnItems) {
            return '<div class="inventory-column flex min-w-0 flex-1 flex-col gap-px bg-outline-variant/20">' +
              columnItems.map(renderItemMarkup).join("") +
            '</div>';
          }).join("") + '</div>';
        }

        function formatDateLabel(isoText) {
          if (!isoText) return "--/--/----";
          const date = new Date(isoText);
          if (Number.isNaN(date.getTime())) return "--/--/----";
          return new Intl.DateTimeFormat("fr-FR", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric"
          }).format(date);
        }

        function formatDateTimeCompact_(isoText) {
          if (!isoText) return "-";
          const date = new Date(isoText);
          if (Number.isNaN(date.getTime())) return String(isoText || "").trim() || "-";
          return new Intl.DateTimeFormat("fr-FR", {
            day: "2-digit",
            month: "2-digit",
            hour: "2-digit",
            minute: "2-digit"
          }).format(date).replace(",", "");
        }

        function formatHistoryActionLabel_(actionType) {
          const normalized = String(actionType || "").trim();
          if (normalized === "sortie_rapide") return "sortie_rapide";
          if (normalized === "modifier") return "modifier";
          return normalized || "-";
        }

        function getHistoryActionBadgeClass_(actionType) {
          const normalized = String(actionType || "").trim();
          if (normalized === "sortie_rapide") {
            return "bg-error-container/25 text-on-error-container";
          }
          if (normalized === "modifier") {
            return "bg-primary-container text-on-primary-container";
          }
          return "bg-surface-container-high text-on-surface-variant";
        }

        function summarizeDetailItem_(item) {
          if (!item) return "-";
          const parts = [];
          if (toPositiveNumber(item.tail) > 0) {
            parts.push("尾箱 " + formatTailDisplay(item.tail));
          }
          if (toPositiveNumber(item.unitsPerBox) > 0) {
            parts.push("件/箱 " + formatUnitsPerBoxDisplay(item.unitsPerBox));
          }
          if (toPositiveNumber(item.itemBoxes) > 0) {
            parts.push("箱数 " + formatMetricNumber(item.itemBoxes));
          }
          const fractionText = sanitizeFractionText(item.fractionText) || fractionToText(item.fractionValue);
          if (fractionText) {
            parts.push("分数 " + fractionText);
          }
          const packNotation = getMainPackNotationFromState_(item);
          if (packNotation) {
            parts.push(packNotation);
          }
          return parts.length ? parts.join(" · ") : "-";
        }

        function getVisibleHistoryItems_() {
          const query = normalizeText(state.historyView.query);
          const actionType = String(state.historyView.actionType || "").trim();
          const allItems = Array.isArray(state.historyView.items) ? state.historyView.items : [];
          return allItems.filter(function(entry) {
            if (!entry) return false;
            if (actionType && entry.actionType !== actionType) return false;
            if (!query) return true;
            const haystack = [
              entry.reference,
              entry.actionType,
              entry.remark,
              entry.source,
              entry.beforeDisplay,
              entry.afterDisplay
            ].map(normalizeText).join(" ");
            return haystack.indexOf(query) !== -1;
          });
        }

        function getHistoryItemsForReference_(reference) {
          const normalizedReference = String(reference || "").trim();
          if (!normalizedReference) return [];
          return (Array.isArray(state.historyView.items) ? state.historyView.items : []).filter(function(entry) {
            return entry && entry.reference === normalizedReference;
          });
        }

        function syncDetailFromState_(reference) {
          const normalizedReference = String(reference || "").trim();
          if (!normalizedReference) return;
          const item = state.items.find(function(candidate) {
            return candidate && candidate.reference === normalizedReference;
          }) || null;
          const history = getHistoryItemsForReference_(normalizedReference);
          state.detailReference = normalizedReference;
          state.detailView.item = item ? Object.assign({}, item) : null;
          state.detailView.history = cloneDetailHistoryEntries_(history.slice(0, 20));
          state.detailView.historyOffset = history.length;
          state.detailView.hasMoreHistory = false;
          state.detailView.lastMovementAt = history.length ? history[0].timestampRaw : "";
          state.detailView.notFoundInStock = !item;
          state.detailView.loading = false;
          state.detailView.error = "";
        }

        function resetHistoryOriginToInventoryList_() {
          state.historyOrigin = {
            kind: "inventory-list",
            reference: ""
          };
        }

        function isFreshTimestamp_(timestampMs, maxAgeMs) {
          const numeric = Number(timestampMs || 0);
          return numeric > 0 && (Date.now() - numeric) < maxAgeMs;
        }

        function isHistoryPrefetchFresh_() {
          return isFreshTimestamp_(state.historyView.prefetchedAt, 60000);
        }

        function ensureDetailCacheEntry_(reference) {
          const normalizedReference = String(reference || "").trim();
          if (!normalizedReference) return null;
          if (!state.detailCacheByReference[normalizedReference]) {
            state.detailCacheByReference[normalizedReference] = {
              item: null,
              history: [],
              historyOffset: 0,
              hasMoreHistory: false,
              generatedAt: "",
              lastMovementAt: "",
              notFoundInStock: false,
              isWarm: false,
              fetchedAt: 0,
              isStale: false,
              requestToken: 0
            };
          }
          return state.detailCacheByReference[normalizedReference];
        }

        function isDetailCacheFresh_(reference) {
          const cacheEntry = ensureDetailCacheEntry_(reference);
          if (!cacheEntry) return false;
          return !cacheEntry.isStale && isFreshTimestamp_(cacheEntry.fetchedAt, 60000);
        }

        function cloneDetailHistoryEntries_(history) {
          return (Array.isArray(history) ? history : []).map(function(entry) {
            return Object.assign({}, entry);
          });
        }

        function writeDetailCacheFromPayload_(reference, payload, requestToken, options) {
          const cacheEntry = ensureDetailCacheEntry_(reference);
          if (!cacheEntry) return null;
          if (requestToken && cacheEntry.requestToken && cacheEntry.requestToken !== requestToken) {
            return cacheEntry;
          }
          const historyItems = cloneDetailHistoryEntries_(payload && payload.history);
          cacheEntry.item = payload && payload.item ? Object.assign({}, payload.item) : null;
          cacheEntry.history = options && options.appendHistory
            ? cacheEntry.history.concat(historyItems)
            : historyItems;
          cacheEntry.historyOffset = Number(payload && payload.nextHistoryOffset || 0) || 0;
          cacheEntry.hasMoreHistory = !!(payload && payload.hasMoreHistory);
          cacheEntry.generatedAt = payload && payload.generatedAt ? payload.generatedAt : "";
          cacheEntry.lastMovementAt = payload && payload.lastMovementAt ? payload.lastMovementAt : "";
          cacheEntry.notFoundInStock = !!(payload && payload.notFoundInStock);
          cacheEntry.isWarm = true;
          cacheEntry.fetchedAt = Date.now();
          cacheEntry.isStale = false;
          return cacheEntry;
        }

        function applyDetailCacheToView_(reference, cacheEntry, options) {
          if (!cacheEntry) return;
          const shouldAppendHistory = !!(options && options.appendHistory);
          if (!shouldAppendHistory) {
            state.detailReference = reference;
            state.detailView.item = cacheEntry.item ? Object.assign({}, cacheEntry.item) : null;
            state.detailView.history = cloneDetailHistoryEntries_(cacheEntry.history);
            state.detailView.historyOffset = cacheEntry.historyOffset;
            state.detailView.hasMoreHistory = !!cacheEntry.hasMoreHistory;
            state.detailView.notFoundInStock = !!cacheEntry.notFoundInStock;
            state.detailView.lastMovementAt = cacheEntry.lastMovementAt || "";
          } else {
            state.detailView.history = cloneDetailHistoryEntries_(cacheEntry.history);
            state.detailView.historyOffset = cacheEntry.historyOffset;
            state.detailView.hasMoreHistory = !!cacheEntry.hasMoreHistory;
          }
          if (options && options.loading !== undefined) {
            state.detailView.loading = !!options.loading;
          }
          renderDetailView_();
        }

        function markAllDetailCacheStale_() {
          Object.keys(state.detailCacheByReference || {}).forEach(function(reference) {
            const entry = state.detailCacheByReference[reference];
            if (entry) entry.isStale = true;
          });
        }

        function pruneDetailCacheAgainstItems_(items) {
          const visibleReferences = new Set((Array.isArray(items) ? items : []).map(function(item) {
            return String(item && item.reference ? item.reference : "").trim();
          }).filter(Boolean));
          Object.keys(state.detailCacheByReference || {}).forEach(function(reference) {
            const entry = state.detailCacheByReference[reference];
            if (!entry) return;
            if (!visibleReferences.has(reference) && entry.notFoundInStock !== true) {
              entry.isStale = true;
            }
          });
        }

        function nextDetailRequestToken_(reference) {
          state.detailRequestCounter += 1;
          const token = state.detailRequestCounter;
          const cacheEntry = ensureDetailCacheEntry_(reference);
          if (cacheEntry) cacheEntry.requestToken = token;
          return token;
        }

        function maybeScheduleHistoryPrefetch_() {
          const historyView = state.historyView;
          if (state.inventoryLoading || state.inventoryNeedsHydration) return;
          if (historyView.prefetchStarted || historyView.loading) return;
          historyView.prefetchStarted = true;
          window.setTimeout(function() {
            loadHistory_({
              markPrefetched: true
            });
          }, 160);
        }

        function getWarmupReferences_() {
          const visibleItems = getVisibleItems().slice(0, state.detailWarmup.maxRefs);
          return visibleItems
            .map(function(item) { return String(item && item.reference ? item.reference : "").trim(); })
            .filter(function(reference) {
              return !!reference && !isDetailCacheFresh_(reference);
            });
        }

        function consumeDetailWarmupQueue_() {
          const warmup = state.detailWarmup;
          if (warmup.activeCount >= warmup.maxConcurrency) return;
          if (state.currentView === "detail" && state.detailView.loading) {
            window.clearTimeout(warmup.scheduledTimer || 0);
            warmup.scheduledTimer = window.setTimeout(function() {
              consumeDetailWarmupQueue_();
            }, 220);
            return;
          }
          const nextReference = warmup.queue.shift();
          if (!nextReference) return;
          warmup.activeCount += 1;
          fetchDetailPayload_(nextReference, {
            updateActiveView: false,
            warmup: true,
            historyLimit: 5
          }).finally(function() {
            warmup.activeCount = Math.max(0, warmup.activeCount - 1);
            consumeDetailWarmupQueue_();
          });
        }

        function scheduleDetailWarmup_() {
          const warmup = state.detailWarmup;
          window.clearTimeout(warmup.scheduledTimer || 0);
          warmup.generation += 1;
          const generation = warmup.generation;
          warmup.scheduledTimer = window.setTimeout(function() {
            if (generation !== warmup.generation) return;
            warmup.queue = getWarmupReferences_();
            if (!warmup.queue.length) return;
            consumeDetailWarmupQueue_();
          }, 180);
        }

        function buildOptimisticDetailHistoryEntry_(request, beforeItem, afterItem) {
          if (!request || !afterItem) return null;
          return {
            timestampRaw: new Date().toISOString(),
            timestampLabel: formatDateTimeCompact_(new Date().toISOString()),
            actionType: request.mode === "quick-exit" ? "sortie_rapide" : "modifier",
            reference: afterItem.reference,
            beforeDisplay: beforeItem && beforeItem.stockDisplay ? beforeItem.stockDisplay : "",
            afterDisplay: afterItem.stockDisplay || "",
            remark: String(request.remark || "").trim(),
            source: "sync...",
            isOptimistic: true
          };
        }

        function applyOptimisticDetailState_(reference, optimisticItem, historyEntry) {
          const normalizedReference = String(reference || "").trim();
          if (!normalizedReference || !optimisticItem) return;
          const cacheEntry = ensureDetailCacheEntry_(normalizedReference);
          if (cacheEntry) {
            cacheEntry.item = Object.assign({}, optimisticItem);
            cacheEntry.fetchedAt = Date.now();
            cacheEntry.isStale = false;
            if (historyEntry) {
              cacheEntry.history = [Object.assign({}, historyEntry)].concat(
                cloneDetailHistoryEntries_(cacheEntry.history).filter(function(entry) {
                  return !entry || !entry.isOptimistic;
                })
              );
            }
          }
          if (state.detailReference === normalizedReference) {
            state.detailView.item = Object.assign({}, optimisticItem);
            if (historyEntry) {
              state.detailView.history = [Object.assign({}, historyEntry)].concat(
                cloneDetailHistoryEntries_(state.detailView.history).filter(function(entry) {
                  return !entry || !entry.isOptimistic;
                })
              );
            }
            renderDetailView_();
          }
        }

        function rollbackDetailOptimisticState_(reference, previousItem) {
          const normalizedReference = String(reference || "").trim();
          if (!normalizedReference) return;
          const cacheEntry = ensureDetailCacheEntry_(normalizedReference);
          if (cacheEntry) {
            cacheEntry.item = previousItem ? Object.assign({}, previousItem) : null;
            cacheEntry.history = cloneDetailHistoryEntries_(cacheEntry.history).filter(function(entry) {
              return !entry || !entry.isOptimistic;
            });
          }
          if (state.detailReference === normalizedReference) {
            state.detailView.item = previousItem ? Object.assign({}, previousItem) : null;
            state.detailView.history = cloneDetailHistoryEntries_(state.detailView.history).filter(function(entry) {
              return !entry || !entry.isOptimistic;
            });
            renderDetailView_();
          }
        }

        function fetchDetailPayload_(reference, options) {
          if (typeof google === "undefined" || !google.script || !google.script.run) {
            return Promise.resolve(null);
          }
          const normalizedReference = String(reference || "").trim();
          if (!normalizedReference) return Promise.resolve(null);
          const requestToken = nextDetailRequestToken_(normalizedReference);
          const updateActiveView = !!(options && options.updateActiveView);
          if (updateActiveView) {
            state.detailView.activeRequestToken = requestToken;
          }
          return new Promise(function(resolve) {
            google.script.run
              .withSuccessHandler(function(payload) {
                const cacheEntry = writeDetailCacheFromPayload_(normalizedReference, payload, requestToken, options);
                const canUpdateActiveView = updateActiveView
                  && state.detailReference === normalizedReference
                  && state.detailView.activeRequestToken === requestToken;
                if (canUpdateActiveView && cacheEntry) {
                  state.detailView.loading = false;
                  state.detailView.error = "";
                  applyDetailCacheToView_(normalizedReference, cacheEntry, {
                    appendHistory: !!(options && options.appendHistory)
                  });
                }
                resolve(payload || null);
              })
              .withFailureHandler(function(error) {
                const cacheEntry = ensureDetailCacheEntry_(normalizedReference);
                if (cacheEntry && cacheEntry.requestToken === requestToken) {
                  cacheEntry.requestToken = requestToken;
                }
                if (updateActiveView
                  && state.detailReference === normalizedReference
                  && state.detailView.activeRequestToken === requestToken) {
                  state.detailView.loading = false;
                  state.detailView.error = error && error.message ? error.message : "Erreur chargement fiche";
                  if (!state.detailView.item) {
                    state.detailView.history = [];
                    state.detailView.hasMoreHistory = false;
                    state.detailView.notFoundInStock = true;
                  }
                  renderDetailView_();
                }
                resolve(null);
              })
              .StockWebApp_getItemDetail(normalizedReference, {
                historyOffset: options && options.appendHistory ? state.detailView.historyOffset : 0,
                historyLimit: options && options.historyLimit ? options.historyLimit : 10
              });
          });
        }

        function scrollContainerToTop_(container) {
          if (!container) return;
          container.scrollTop = 0;
        }

        function updateBottomNav_() {
          const isInventory = state.currentView === "inventory";
          const isHistory = state.currentView === "history";
          els.navInventoryButton.className = "flex flex-1 flex-col items-center justify-center px-2 py-1 " + (isInventory ? "bg-slate-200 text-slate-900" : "text-slate-400");
          els.navHistoryButton.className = "flex flex-1 flex-col items-center justify-center px-2 py-1 " + (isHistory ? "bg-slate-200 text-slate-900" : "text-slate-400");
          els.navInventoryButton.setAttribute("aria-current", isInventory ? "page" : "false");
          els.navHistoryButton.setAttribute("aria-current", isHistory ? "page" : "false");
        }

        function syncCurrentView_() {
          els.inventoryAppShell.classList.toggle("hidden", state.currentView !== "inventory");
          els.historyAppShell.classList.toggle("hidden", state.currentView !== "history");
          els.detailAppShell.classList.toggle("hidden", state.currentView !== "detail");
          updateBottomNav_();
        }

        function buildHistoryRowsMarkup_(items) {
          return (Array.isArray(items) ? items : []).map(function(entry) {
            const beforeMarkup = entry.beforeDisplay
              ? '<div class="text-[11px] text-on-surface"><span class="font-bold uppercase tracking-[0.14em] text-on-surface-variant">AVANT</span><span class="ml-2">' + escapeHtml(entry.beforeDisplay) + '</span></div>'
              : '';
            const afterMarkup = entry.afterDisplay
              ? '<div class="text-[11px] text-on-surface"><span class="font-bold uppercase tracking-[0.14em] text-on-surface-variant">APRÈS</span><span class="ml-2">' + escapeHtml(entry.afterDisplay) + '</span></div>'
              : '';
            const remarkMarkup = entry.remark
              ? '<div class="text-[11px] text-on-surface-variant">' + escapeHtml(entry.remark) + '</div>'
              : '';
            const sourceMarkup = entry.source
              ? '<div class="text-[10px] font-medium uppercase tracking-[0.14em] text-on-surface-variant">' + escapeHtml(entry.source) + '</div>'
              : '';
            return ''
              + '<article class="bg-surface-container-lowest px-4 py-3 shadow-ledger" data-history-reference="' + escapeHtml(entry.reference) + '">'
              + '<div class="flex items-start justify-between gap-3">'
              + '<div class="min-w-0">'
              + '<button class="truncate text-left text-[12px] font-bold tracking-tight text-primary" type="button" data-action="open-history-detail" data-reference="' + escapeHtml(entry.reference) + '">' + escapeHtml(entry.reference || "-") + '</button>'
              + '<div class="mt-1 text-[10px] font-bold uppercase tracking-[0.16em] text-on-surface-variant">' + escapeHtml(entry.timestampLabel || "-") + '</div>'
              + '</div>'
              + '<span class="shrink-0 rounded px-2 py-1 text-[9px] font-bold uppercase tracking-[0.16em] ' + getHistoryActionBadgeClass_(entry.actionType) + '">' + escapeHtml(formatHistoryActionLabel_(entry.actionType)) + '</span>'
              + '</div>'
              + '<div class="mt-3 space-y-1">' + beforeMarkup + afterMarkup + remarkMarkup + sourceMarkup + '</div>'
              + '</article>';
          }).join("");
        }

        function renderHistoryList_(append, incomingItems) {
          const view = state.historyView;
          const items = getVisibleHistoryItems_();
          if (append) {
            els.historyList.insertAdjacentHTML("beforeend", buildHistoryRowsMarkup_(incomingItems));
          } else {
            els.historyList.innerHTML = buildHistoryRowsMarkup_(items);
          }

          const hasItems = items.length > 0;
          const hasFilters = !!(view.query || view.actionType);
          els.historyEmptyState.classList.toggle("hidden", hasItems || view.loading);
          els.historyLoadingState.classList.toggle("hidden", !view.loading || hasItems);
          els.historyLoadMoreWrap.classList.add("hidden");
          els.historyEmptyTitle.textContent = hasFilters ? "Aucun resultat" : "Aucun historique";
          els.historyEmptyMessage.textContent = hasFilters
            ? "Aucun mouvement ne correspond à la recherche."
            : "Aucun mouvement à afficher.";
          els.historySummary.textContent = items.length > 0 ? (items.length + " mouvements") : "-";
          els.historyStatus.textContent = view.loading ? "Chargement..." : "Pret";
        }

        function renderDetailView_() {
          const detail = state.detailView;
          const item = detail.item;
          const history = Array.isArray(detail.history) ? detail.history : [];
          els.detailReference.textContent = state.detailReference || "-";
          els.detailSubline.textContent = detail.loading
