        function openQuickEdit(item) {
          if (!item) return;
          if (isItemPending(item.id)) {
            state.lastError = "";
            setLastSyncFeedback("pending", "Synchronisation...", 0);
            renderSummary(getVisibleItems());
            return;
          }
          state.quickEditItem = item;
          state.quickEditOpen = true;
          state.quickEditTab = "quick-exit";
          state.quickEditSaving = false;
          setQuickEditError("");
          const packNotationParts = splitPackNotation(item.packNotation);
          state.quickEditForm = {
            tailInput: formatTailDisplay(item.tail),
            unitsPerBoxInput: formatUnitsPerBoxDisplay(item.unitsPerBox),
            itemBoxes: sanitizeIntegerInput(item.itemBoxes),
            sign: sanitizeSign(item.sign),
            fractionText: sanitizeFractionText(item.fractionText),
            packNotationSign: packNotationParts.sign,
            packNotationCount: packNotationParts.count,
            remark: String(item.remark || "").trim()
          };
          state.quickEditTailOpen = hasQuickEditTailValue(state.quickEditForm);
          state.quickEditPartialOpen = hasQuickEditPartialValue(state.quickEditForm);
          state.quickExitForm = {
            segments: {}
          };
          state.quickExitClearSelected = false;
          state.quickExitSegmentErrors = {};
          renderQuickEdit();
        }

        function closeQuickEdit() {
          resetQuickEditInlineWidths_();
          els.quickEditExpressionMeasure.style.marginLeft = "";
          els.quickEditExpressionMeasure.style.marginRight = "";
          els.quickEditRemoveMeasure.style.marginLeft = "";
          els.quickEditRemoveMeasure.style.marginRight = "";
          els.quickEditExpressionScroll.scrollLeft = 0;
          els.quickEditRemoveScroll.scrollLeft = 0;
          if (quickEditLayoutFrame_) {
            window.cancelAnimationFrame(quickEditLayoutFrame_);
            quickEditLayoutFrame_ = 0;
          }
          state.quickEditOpen = false;
          state.quickEditItem = null;
          state.quickEditForm = null;
          state.quickEditTailOpen = false;
          state.quickEditPartialOpen = false;
          state.quickExitForm = null;
          state.quickExitClearSelected = false;
          state.quickExitSegmentErrors = {};
          state.quickEditError = "";
          state.quickEditSaving = false;
          renderQuickEdit();
        }

        function toggleQuickEditSegment(segment) {
          if (!state.quickEditForm) return;
          if (segment === "tail") {
            state.quickEditTailOpen = !state.quickEditTailOpen;
          } else if (segment === "partial") {
            state.quickEditPartialOpen = !state.quickEditPartialOpen;
          }
          renderQuickEdit();
        }

        function handleQuickEditFieldChange(field, value) {
          if (!state.quickEditForm) return;
          if (field === "tailInput" || field === "unitsPerBoxInput") {
            state.quickEditForm[field] = String(value || "");
          } else if (field === "packNotationSign") {
            state.quickEditForm.packNotationSign = String(value || "") === "-" ? "-" : "+";
          } else if (field === "packNotationCount") {
            state.quickEditForm.packNotationCount = sanitizeIntegerInput(value);
          } else if (field === "remark") {
            state.quickEditForm.remark = String(value || "");
          } else if (field === "sign") {
            state.quickEditForm.sign = sanitizeSign(value);
          } else if (field === "fractionText") {
            state.quickEditForm.fractionText = sanitizeFractionText(value);
          } else {
            state.quickEditForm[field] = sanitizeIntegerInput(value);
          }
          setQuickEditError("");
          renderQuickEdit();
        }

        function handleQuickExitFieldChange(field, value) {
          updateQuickExitSegmentConfig_("main", field, value);
        }

        function validateEditPayload() {
          if (!state.quickEditItem || !state.quickEditForm) return null;
          const tailResult = parseStyledIntegerInput(state.quickEditForm.tailInput);
          const unitsResult = parseStyledIntegerInput(state.quickEditForm.unitsPerBoxInput);
          const itemBoxes = Number(state.quickEditForm.itemBoxes || 0);
          const fractionText = sanitizeFractionText(state.quickEditForm.fractionText);
          const packNotation = buildPackNotationValue(state.quickEditForm.packNotationSign, state.quickEditForm.packNotationCount);
          const remark = String(state.quickEditForm.remark || "").trim();

          if (!tailResult.valid) {
            setQuickEditError("尾箱 invalide. Exemple attendu: (85p).");
            return null;
          }
          if (!unitsResult.valid) {
            setQuickEditError("件/箱 invalide. Exemple attendu: 144p.");
            return null;
          }
          if (!isFractionTextValid(fractionText)) {
            setQuickEditError("Fraction invalide. Exemple attendu: 1/2.");
            return null;
          }
          return {
            id: state.quickEditItem.id,
            reference: state.quickEditItem.reference,
            mode: "edit",
            tail: tailResult.value,
            unitsPerBox: unitsResult.value,
            itemBoxes: Math.max(0, Math.trunc(Number.isFinite(itemBoxes) ? itemBoxes : 0)),
            sign: sanitizeSign(state.quickEditForm.sign),
            fractionText: fractionText,
            packNotationSign: state.quickEditForm.packNotationSign,
            packNotationCount: Math.max(0, Math.trunc(Number(state.quickEditForm.packNotationCount) || 0)),
            packNotation: packNotation,
            remark: remark
          };
        }

        function validateQuickExitPayload() {
          if (!state.quickEditItem) return null;
          const item = state.quickEditItem;
          if (state.quickExitClearSelected) {
            resetQuickExitErrors_();
            return {
              id: item.id,
              reference: item.reference,
              mode: "edit",
              tail: 0,
              unitsPerBox: Math.max(0, Math.trunc(Number(item.unitsPerBox) || 0)),
              itemBoxes: 0,
              sign: "",
              fractionText: "",
              packNotationSign: "+",
              packNotationCount: 0,
              packNotation: "",
              remark: String(state.quickEditForm && state.quickEditForm.remark || "").trim(),
              fractionValue: 0
            };
          }
          if (!state.quickExitForm) return null;
          const result = buildQuickExitResultState_(item);
          if (!result || !result.valid || !result.nextState) {
            state.quickExitSegmentErrors = result && result.segmentErrors ? result.segmentErrors : {};
            setQuickEditError(result && result.message ? result.message : "Selectionne au moins un segment de sortie.");
            return null;
          }
          state.quickExitSegmentErrors = {};
          const nextState = result.nextState;
          const nextMeta = buildPackMeta(nextState);
          return {
            id: item.id,
            reference: item.reference,
            mode: "edit",
            tail: Math.max(0, Math.trunc(Number(nextState.tail) || 0)),
            unitsPerBox: Math.max(0, Math.trunc(Number(nextState.unitsPerBox) || 0)),
            itemBoxes: Math.max(0, Math.trunc(Number(nextState.itemBoxes) || 0)),
            sign: sanitizeSign(nextState.sign),
            fractionText: sanitizeFractionText(nextState.fractionText),
            packNotationSign: splitPackNotation(nextState.packNotation).sign,
            packNotationCount: Math.max(0, Math.trunc(Number(splitPackNotation(nextState.packNotation).count) || 0)),
            packNotation: normalizePackNotation(nextState.packNotation, false),
            remark: String(state.quickEditForm && state.quickEditForm.remark || "").trim(),
            packsPerBox: nextMeta.packsPerBox
          };
        }

        function handleQuickEditSaveSuccess(itemId, startedAt, result) {
          const normalizedId = String(itemId || "").trim();
          const pending = normalizedId ? state.pendingSaveById[normalizedId] : null;
          if (!pending) return;
          if (pending.startedAt !== startedAt) return;

          const updatedItem = result && result.item ? result.item : null;
          clearPendingSaveEntry(normalizedId);

          const replaced = !!(updatedItem && replaceItemInState(updatedItem));
          if (updatedItem && state.detailReference && updatedItem.reference === state.detailReference) {
            syncDetailFromState_(updatedItem.reference);
            renderDetailView_();
          }

          if (!updatedItem || (!replaced && !(state.detailReference && updatedItem.reference === state.detailReference))) {
            setLastSyncFeedback("error", "Échec enregistrement", 3200);
            renderGrid();
            return;
          }

          state.lastError = "";
          setLastSyncFeedback("success", "Enregistré", 2800);
          renderGrid();
        }

        function handleQuickEditSaveFailure(itemId, startedAt, error) {
          const normalizedId = String(itemId || "").trim();
          const pendingEntry = normalizedId ? state.pendingSaveById[normalizedId] : null;
          if (!pendingEntry) return;
          if (pendingEntry.startedAt !== startedAt) return;

          if (pendingEntry && pendingEntry.previousItem) {
            replaceItemInState(pendingEntry.previousItem);
            if (state.detailReference && pendingEntry.previousItem.reference === state.detailReference) {
              syncDetailFromState_(pendingEntry.previousItem.reference);
              renderDetailView_();
            }
          }
          clearPendingSaveEntry(normalizedId);
          state.lastError = "";
          setLastSyncFeedback("error", "Échec enregistrement", 3200);
          renderGrid();
        }

        function handleQuickEditSave() {
          if (state.quickEditSaving) return;
          if (typeof google === "undefined" || !google.script || !google.script.run) {
            setQuickEditError("Sauvegarde indisponible dans ce contexte.");
            renderQuickEdit();
            return;
          }

          const request = state.quickEditTab === "quick-exit"
            ? validateQuickExitPayload()
            : validateEditPayload();
          if (!request) {
            renderQuickEdit();
            return;
          }

          const currentItem = getItemById(request.id) || (state.quickEditItem && state.quickEditItem.id === request.id ? state.quickEditItem : null);
          if (!currentItem) {
            setQuickEditError("Reference introuvable. Merci de rafraichir.");
            renderQuickEdit();
            return;
          }
          const itemId = String(currentItem.id || "").trim();
          if (isItemPending(itemId)) {
            setQuickEditError("Synchronisation en cours sur cette reference.");
            renderQuickEdit();
            return;
          }

          const optimisticItem = buildOptimisticItemFromRequest(currentItem, request);
          if (!optimisticItem) {
            setQuickEditError("Impossible de calculer la mise a jour locale.");
            renderQuickEdit();
            return;
          }
          const optimisticHistoryEntry = buildOptimisticDetailHistoryEntry_(request, currentItem, optimisticItem);

          const startedAt = Date.now();
          const timeoutId = window.setTimeout(function() {
            if (state.pendingSaveById[itemId]?.startedAt !== startedAt) return;
            const timeoutEntry = state.pendingSaveById[itemId];
            if (!timeoutEntry) return;
            if (timeoutEntry.previousItem) {
              replaceItemInState(timeoutEntry.previousItem);
              if (state.detailReference && timeoutEntry.previousItem.reference === state.detailReference) {
                syncDetailFromState_(timeoutEntry.previousItem.reference);
                renderDetailView_();
              }
            }
            clearPendingSaveEntry(itemId);
            state.lastError = "";
            setLastSyncFeedback("error", "Timeout", 3000);
            renderGrid();
          }, 10000);

          state.quickEditSaving = true;
          setQuickEditError("");
          state.pendingSaveById[itemId] = {
            previousItem: Object.assign({}, currentItem),
            optimisticItem: Object.assign({}, optimisticItem),
            request: Object.assign({}, request),
            startedAt: startedAt,
            status: "pending",
            timeoutId: timeoutId,
            optimisticHistoryEntry: optimisticHistoryEntry ? Object.assign({}, optimisticHistoryEntry) : null
          };
          if (optimisticItem) {
            replaceItemInState(optimisticItem);
            if (state.detailReference && optimisticItem.reference === state.detailReference) {
              state.detailView.item = Object.assign({}, optimisticItem);
              if (optimisticHistoryEntry) {
                state.detailView.history = [Object.assign({}, optimisticHistoryEntry)].concat(
                  cloneDetailHistoryEntries_(getHistoryItemsForReference_(optimisticItem.reference)).filter(function(entry) {
                    return !entry || !entry.isOptimistic;
                  }).slice(0, 19)
                );
              } else {
                state.detailView.history = cloneDetailHistoryEntries_(getHistoryItemsForReference_(optimisticItem.reference).slice(0, 20));
              }
              renderDetailView_();
            }
          }
          closeQuickEdit();
          renderGrid();
          state.lastError = "";
          setLastSyncFeedback("pending", "Synchronisation...", 0);
          renderSummary(getVisibleItems());

          google.script.run
            .withSuccessHandler(function(result) {
              handleQuickEditSaveSuccess(itemId, startedAt, result);
            })
            .withFailureHandler(function(error) {
              handleQuickEditSaveFailure(itemId, startedAt, error);
            })
            .StockWebApp_saveQuickEdit(request);
        }

        function handleOpenReferenceDetail(reference) {
          const normalizedReference = String(reference || "").trim();
          if (!normalizedReference) return;
          state.previousView = state.currentView === "history" ? "history" : "inventory";
          state.lastOpenedDetailReference = normalizedReference;
          state.lastError = "";
          loadDetailView_(normalizedReference, { appendHistory: false });
        }

        function renderSummary(visibleItems) {
          const positiveCount = visibleItems.filter(function(item) {
            return item && item.stockState === "positive";
          }).length;
          const totals = computeInventoryTotals_(visibleItems);
          const totalLoaded = state.summary && state.summary.totalRows ? state.summary.totalRows : state.items.length;
          const refsText = state.summary && state.summary.isPartial && state.items.length < totalLoaded
            ? visibleItems.length + " / " + totalLoaded + " " + (visibleItems.length === 1 ? "ref" : "refs")
            : visibleItems.length + " " + (visibleItems.length === 1 ? "ref" : "refs");
          const summarySegments = [
            formatMetricNumber(totals.totalBoxes) + "箱"
          ];

          if (totals.hasPackData && totals.totalPacks > 0) {
            summarySegments.push(formatMetricNumber(totals.totalPacks) + "包");
          }
          summarySegments.push(formatMetricNumber(totals.totalPieces) + "件");

          els.summaryDate.textContent = formatDateLabel(state.generatedAt || (state.summary && state.summary.generatedAt) || "");
          els.summaryRefs.textContent = refsText;
          els.summaryPositive.textContent = positiveCount + " en stock";
          els.summaryZero.textContent = Math.max(0, visibleItems.length - positiveCount) + " en rupture";
          els.summaryTotals.textContent = summarySegments.join(" ");

          updateSyncStatus_();
        }

        function renderGrid() {
          const visibleItems = getVisibleItems();
          const columns = buildColumnLayout_(visibleItems, state.columnCount);
          if (state.inventoryLoading && !state.items.length) {
            els.grid.innerHTML = renderInventoryLoadingMarkup_();
          } else {
            els.grid.innerHTML = renderColumnLayoutMarkup(columns);
          }
          els.emptyState.classList.toggle("hidden", state.inventoryLoading || visibleItems.length > 0);
          renderSummary(visibleItems);
          renderActiveFilters();
          scheduleDetailWarmup_();
        }

        function syncUtilityPanel() {
          els.utilityPanel.classList.toggle("hidden", !state.filterPanelOpen);
          els.sortSelect.value = state.sort;
          els.stockStateFilter.value = state.stockState;
          els.sortBadge.textContent = state.sort === "ref_desc" ? "REF DESC" : (state.sort === "stock_first" ? "STOCK" : "REF ASC");
        }

        function populateWarehouseFilter() {
          const warehouses = state.filters && Array.isArray(state.filters.warehouses) ? state.filters.warehouses : [];
          els.warehouseFilter.innerHTML = '<option value="">Tous</option>' + warehouses.map(function(value) {
            return '<option value="' + escapeHtml(value) + '">' + escapeHtml(value) + '</option>';
          }).join("");
          els.warehouseFilter.value = state.warehouse;
          els.warehouseFilterWrap.classList.toggle("hidden", warehouses.length === 0);
        }

        function mergeInventoryItems_(incomingItems) {
          const byId = {};
          state.items.forEach(function(item) {
            const id = String(item && item.id ? item.id : "").trim();
            if (id) byId[id] = item;
          });
          (Array.isArray(incomingItems) ? incomingItems : []).forEach(function(item) {
            const id = String(item && item.id ? item.id : "").trim();
            if (id) byId[id] = item;
          });
          return Object.keys(byId).map(function(id) {
            return byId[id];
          });
        }

        function hydrate(payload, options) {
          markAllDetailCacheStale_();
          state.items = options && options.mergeItems
            ? mergeInventoryItems_(payload && payload.items)
            : (Array.isArray(payload && payload.items) ? payload.items.slice() : []);
          state.filters = payload && payload.filters ? payload.filters : {};
          state.summary = payload && payload.summary ? payload.summary : {};
          state.generatedAt = payload && payload.generatedAt ? payload.generatedAt : "";
          state.lastError = "";
          pruneDetailCacheAgainstItems_(state.items);
          populateWarehouseFilter();
          syncUtilityPanel();
          renderGrid();
          maybeScheduleHistoryPrefetch_();
        }

        function syncColumnLayout(force) {
          const nextCount = getColumnCount();
          if (!force && nextCount === state.columnCount) return;
          state.columnCount = nextCount;
          renderGrid();
        }

        function runRefresh(isAuto) {
          if (state.isRefreshing) return;
          if (typeof google === "undefined" || !google.script || !google.script.run) return;
          state.isRefreshing = true;
          state.lastError = "";
          renderSummary(getVisibleItems());

          google.script.run
            .withSuccessHandler(function(payload) {
              state.isRefreshing = false;
              state.inventoryLoading = false;
              state.inventoryLoaded = true;
              const shouldMerge = !!state.inventoryNeedsHydration && state.items.length > 0;
              state.inventoryNeedsHydration = false;
              hydrate(payload || {}, { mergeItems: shouldMerge });
            })
            .withFailureHandler(function(error) {
              state.isRefreshing = false;
              state.inventoryLoading = false;
              state.inventoryNeedsHydration = false;
              state.lastError = error && error.message ? error.message : "Erreur de rafraichissement";
              renderGrid();
            })
            .StockWebAppV2_getInventory();

          if (isAuto) {
            els.summaryStatus.textContent = "Sync...";
          }
        }

        function loadInitialInventory_() {
          if (state.inventoryNeedsHydration) {
            runRefresh(true);
            return;
          }
          if (!state.inventoryLoading || state.inventoryLoaded) return;
          runRefresh(false);
        }

