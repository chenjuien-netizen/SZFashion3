        }

        function computePacksPerBox(unitsPerBox, colisage) {
          const units = Math.max(0, Math.trunc(Number(unitsPerBox) || 0));
          const packSize = Math.max(0, Math.trunc(Number(colisage) || 0));
          if (!(units > 0) || !(packSize > 0)) return 0;
          if (units % packSize !== 0) return 0;
          return units / packSize;
        }

        function parseStyledIntegerInput(value, options) {
          const text = String(value || "").trim();
          if (!text) return { valid: true, value: 0 };

          const normalized = text
            .replace(/[()]/g, "")
            .replace(/p/gi, "")
            .replace(/\s+/g, "");
          if (!/^\d+$/.test(normalized)) {
            return { valid: false, value: 0 };
          }

          return {
            valid: true,
            value: Math.max(0, Math.trunc(Number(normalized) || 0))
          };
        }

        function gcd(a, b) {
          let left = Math.abs(Math.trunc(a || 0));
          let right = Math.abs(Math.trunc(b || 0));
          while (right) {
            const next = right;
            right = left % right;
            left = next;
          }
          return left || 1;
        }

        function fractionToText(value) {
          const numeric = Number(value || 0);
          if (!Number.isFinite(numeric) || numeric <= 0) return "";
          const candidates = [2, 3, 4, 6, 8, 12];
          let best = null;
          let bestErr = Infinity;

          candidates.forEach(function(den) {
            const num = Math.round(numeric * den);
            const approx = num / den;
            const err = Math.abs(numeric - approx);
            if (err < bestErr) {
              bestErr = err;
              best = { num: num, den: den };
            }
          });

          if (!best || !best.den || best.num <= 0) return "";
          const divisor = gcd(best.num, best.den);
          return (best.num / divisor) + "/" + (best.den / divisor);
        }

        function fractionTextFromPieces(pieces, unitsPerBox) {
          const safePieces = Math.max(0, Math.trunc(Number(pieces) || 0));
          const safeUnits = Math.max(0, Math.trunc(Number(unitsPerBox) || 0));
          if (!(safePieces > 0) || !(safeUnits > 0)) return "";
          const divisor = gcd(safePieces, safeUnits);
          return (safePieces / divisor) + "/" + (safeUnits / divisor);
        }

        function buildRawLocalStockDisplay(stateModel) {
          const tailDisplay = buildTailDisplay_(stateModel);
          const unitsPerBox = Math.max(0, Math.trunc(Number(stateModel && stateModel.unitsPerBox) || 0));
          const itemBoxes = Math.max(0, Math.trunc(Number(stateModel && stateModel.itemBoxes) || 0));
          const sign = String(stateModel && stateModel.sign ? stateModel.sign : "").trim();
          const fractionText = sanitizeFractionText(stateModel && stateModel.fractionText) || fractionToText(stateModel && stateModel.fractionValue);
          const hasMainContent = itemBoxes > 0 || !!fractionText;
          let core = "";

          if (unitsPerBox > 0 && hasMainContent) {
            core = unitsPerBox + "p";
            if (sign === "×" && fractionText) {
              if (itemBoxes > 1) {
                core += "×" + itemBoxes + "×" + fractionText;
              } else {
                core += "×" + fractionText;
              }
            } else if (sign === "+" && fractionText) {
              core += "×" + itemBoxes + "+" + fractionText;
            } else if (itemBoxes > 0) {
              core += "×" + itemBoxes;
            }
          }

          if (tailDisplay) {
