        }

        function stateModelToPieces(stateModel) {
          const tail = getTailActualPieces_(stateModel);
          const unitsPerBox = Math.max(0, Math.trunc(Number(stateModel && stateModel.unitsPerBox) || 0));
          const itemBoxes = Math.max(0, Math.trunc(Number(stateModel && stateModel.itemBoxes) || 0));
          const sign = String(stateModel && stateModel.sign ? stateModel.sign : "").trim();
          const fractionValue = toPositiveNumber(stateModel && stateModel.fractionValue) || parseFraction(stateModel && stateModel.fractionText);
          const colisage = Math.max(0, Math.trunc(Number(stateModel && stateModel.colisage) || 0));
          const packMeta = parsePackNotation(getMainPackNotationFromState_(stateModel));
          let totalPieces = tail;

          if (unitsPerBox > 0) {
            if (sign === "+") {
              totalPieces += (unitsPerBox * itemBoxes) + (unitsPerBox * fractionValue);
            } else if (sign === "×") {
              if (itemBoxes > 1) {
                totalPieces += unitsPerBox * itemBoxes * fractionValue;
