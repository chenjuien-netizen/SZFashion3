        }

        function parsePackNotation(value) {
          const normalized = normalizePackNotation(value, false);
          const match = normalized.match(/^([+-])(\d+)包$/);
          if (!match) {
            return { notation: normalized, sign: "", count: 0, valid: !normalized };
          }
          return {
            notation: normalized,
            sign: match[1],
            count: Number(match[2]) || 0,
            valid: true
