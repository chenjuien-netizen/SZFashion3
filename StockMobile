        function compareBySortKey(left, right) {
          const leftSortKey = String(left && left.sortKey ? left.sortKey : "").trim();
          const rightSortKey = String(right && right.sortKey ? right.sortKey : "").trim();
          const leftRef = String(left && left.reference ? left.reference : "");
          const rightRef = String(right && right.reference ? right.reference : "");

          if (leftSortKey && rightSortKey && leftSortKey !== rightSortKey) {
            return leftSortKey.localeCompare(rightSortKey);
          }
          if (leftSortKey && !rightSortKey) return -1;
          if (!leftSortKey && rightSortKey) return 1;
          return leftRef.localeCompare(rightRef);
        }

        function sortItems(items) {
          const next = items.slice();
