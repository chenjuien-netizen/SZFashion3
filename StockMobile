            + '<span class="text-on-surface-variant">包</span>';
        }

        function clampNumber(value, min, max) {
          return Math.max(min, Math.min(max, value));
        }

        function getControlTextWidth_(value, fallbackValue, minChars, maxChars, extraChars) {
          const source = String(value || fallbackValue || "").trim();
          const effectiveLength = source ? source.length : 0;
          return clampNumber(effectiveLength + (extraChars || 0), minChars, maxChars);
        }

        function setFieldWidth_(fieldEl, inputEl, value, fallbackValue, minChars, maxChars, extraChars) {
          if (!fieldEl || !inputEl) return;
          const widthInCh = getControlTextWidth_(value, fallbackValue, minChars, maxChars, extraChars);
          fieldEl.style.width = widthInCh + "ch";
          inputEl.style.width = widthInCh + "ch";
        }

        function isVisibleQuickEditAnchor_(element) {
          if (!element || element.classList.contains("hidden")) return false;
          const rect = element.getBoundingClientRect();
          return rect.width > 0 && rect.height > 0;
        }

        function getQuickEditAnchor_(inputEl, fallbackEl) {
          if (isVisibleQuickEditAnchor_(inputEl)) return inputEl;
          if (isVisibleQuickEditAnchor_(fallbackEl)) return fallbackEl;
          return null;
        }

        function clearQuickEditOperatorPosition_(operatorEl) {
          if (!operatorEl) return;
          operatorEl.style.left = "";
          operatorEl.style.top = "";
          operatorEl.style.transform = "";
        }

        function positionQuickEditOperatorBetween_(operatorEl, leftAnchorEl, rightAnchorEl) {
          if (!operatorEl || !leftAnchorEl || !rightAnchorEl || !els.quickEditExpressionLine) {
            clearQuickEditOperatorPosition_(operatorEl);
            return;
          }
          const lineRect = els.quickEditExpressionLine.getBoundingClientRect();
          const leftRect = leftAnchorEl.getBoundingClientRect();
          const rightRect = rightAnchorEl.getBoundingClientRect();
          if (!(lineRect.width > 0 && lineRect.height > 0 && leftRect.width > 0 && rightRect.width > 0)) {
            clearQuickEditOperatorPosition_(operatorEl);
            return;
          }
          const centerX = ((leftRect.left + (leftRect.width / 2)) + (rightRect.left + (rightRect.width / 2))) / 2;
          const centerY = ((leftRect.top + (leftRect.height / 2)) + (rightRect.top + (rightRect.height / 2))) / 2;
          operatorEl.style.left = (centerX - lineRect.left) + "px";
          operatorEl.style.top = (centerY - lineRect.top) + "px";
          operatorEl.style.transform = "translate(-50%, -50%)";
        }

        function syncWidthPair_(sourceEl, targetEl) {
          if (!sourceEl || !targetEl) return;
          targetEl.style.width = "";
          if (targetEl.classList.contains("hidden") || sourceEl.classList.contains("hidden")) {
            return;
          }
          const width = sourceEl.offsetWidth;
          if (!width) {
            return;
          }
          targetEl.style.width = width + "px";
        }

        function resetQuickEditInlineWidths_() {
          [
            els.quickEditTailRemoveSlot,
            els.quickEditTailRemoveJoinSlot,
            els.quickEditUnitsPerBoxRemoveSpacer,
            els.quickEditMultiplyRemoveSpacerSlot,
            els.quickEditItemBoxesRemoveSpacer,
            els.quickEditPartialRemoveSlot,
            els.quickEditRemoveMeasure
          ].forEach(function(element) {
            if (element) element.style.width = "";
          });
        }

        function syncQuickEditOperatorSlots_() {
          syncWidthPair_(els.quickEditTailJoinSlot, els.quickEditTailRemoveJoinSlot);
          syncWidthPair_(els.quickEditMultiplyJoinSlot, els.quickEditMultiplyRemoveSpacerSlot);
        }

        function syncQuickEditOperatorPositions_() {
          const tailAnchor = getQuickEditAnchor_(els.quickEditTail, els.quickEditTailToggle);
          const unitsAnchor = getQuickEditAnchor_(els.quickEditUnitsPerBox, null);
          const boxesAnchor = getQuickEditAnchor_(els.quickEditItemBoxes, null);
          positionQuickEditOperatorBetween_(els.quickEditTailJoin, tailAnchor, unitsAnchor);
          positionQuickEditOperatorBetween_(els.quickEditMultiplyJoin, unitsAnchor, boxesAnchor);
        }

        function hasVisibleQuickEditRemove_() {
          return !els.quickEditTailRemove.classList.contains("hidden") || !els.quickEditPartialRemoveSlot.classList.contains("hidden");
        }

        function centerQuickEditMeasuredBlock_(scrollEl, measureEl, measuredWidth) {
          if (!scrollEl || !measureEl) return;
          const viewportWidth = scrollEl.clientWidth;
          const contentWidth = measuredWidth || 0;
          measureEl.style.marginLeft = "";
          measureEl.style.marginRight = "";
          if (viewportWidth > 0 && contentWidth > 0 && contentWidth <= viewportWidth + 1) {
            measureEl.style.marginLeft = "auto";
            measureEl.style.marginRight = "auto";
            if (scrollEl.scrollLeft !== 0) scrollEl.scrollLeft = 0;
            return;
          }
          if (scrollEl.scrollWidth <= scrollEl.clientWidth + 1 && scrollEl.scrollLeft !== 0) {
            scrollEl.scrollLeft = 0;
          }
        }

        function syncQuickEditMeasuredLayout_(retryCount) {
          quickEditLayoutFrame_ = 0;
          const currentRetry = retryCount || 0;
          resetQuickEditInlineWidths_();
          syncWidthPair_(els.quickEditTailSlot, els.quickEditTailRemoveSlot);
          syncWidthPair_(els.quickEditUnitsPerBoxSlot, els.quickEditUnitsPerBoxRemoveSpacer);
          syncWidthPair_(els.quickEditItemBoxesSlot, els.quickEditItemBoxesRemoveSpacer);
          syncWidthPair_(els.quickEditPartialSlot, els.quickEditPartialRemoveSlot);
          syncQuickEditOperatorSlots_();

          const measuredWidth = Math.round(els.quickEditExpressionMeasure.getBoundingClientRect().width || 0);
          if (!(measuredWidth > 0)) {
            if (currentRetry < 2 && state.quickEditOpen) {
              quickEditLayoutRetry_ = currentRetry + 1;
              quickEditLayoutFrame_ = window.requestAnimationFrame(function() {
                syncQuickEditMeasuredLayout_(quickEditLayoutRetry_);
              });
            }
            return;
          }

          quickEditLayoutRetry_ = 0;
          syncQuickEditOperatorPositions_();
          centerQuickEditMeasuredBlock_(els.quickEditExpressionScroll, els.quickEditExpressionMeasure, measuredWidth);
          if (!els.quickEditRemoveCenterWrap.classList.contains("hidden") && hasVisibleQuickEditRemove_()) {
            els.quickEditRemoveMeasure.style.width = measuredWidth + "px";
            centerQuickEditMeasuredBlock_(els.quickEditRemoveScroll, els.quickEditRemoveMeasure, measuredWidth);
          } else {
            els.quickEditRemoveMeasure.style.width = "";
            els.quickEditRemoveMeasure.style.marginLeft = "";
            els.quickEditRemoveMeasure.style.marginRight = "";
            els.quickEditRemoveScroll.scrollLeft = 0;
          }
        }

        function scheduleQuickEditMeasuredLayout_() {
          if (quickEditLayoutFrame_) {
            window.cancelAnimationFrame(quickEditLayoutFrame_);
          }
          quickEditLayoutRetry_ = 0;
          quickEditLayoutFrame_ = window.requestAnimationFrame(function() {
            quickEditLayoutFrame_ = window.requestAnimationFrame(function() {
              syncQuickEditMeasuredLayout_(0);
            });
          });
        }

        function syncQuickEditFieldWidths_() {
          const form = state.quickEditForm || {};
          setFieldWidth_(els.quickEditTailSegment, els.quickEditTail, form.tailInput, els.quickEditTail.placeholder, 8, 14, 1);
          setFieldWidth_(els.quickEditUnitsPerBoxField, els.quickEditUnitsPerBox, form.unitsPerBoxInput, els.quickEditUnitsPerBox.placeholder, 8, 14, 1);
          setFieldWidth_(els.quickEditItemBoxesField, els.quickEditItemBoxes, form.itemBoxes, "1", 6, 8, 1);
          setFieldWidth_(els.quickEditSignField, els.quickEditSign, els.quickEditSign.value, "+", 7, 8, 0);
          setFieldWidth_(els.quickEditFractionTextField, els.quickEditFractionText, form.fractionText, els.quickEditFractionText.placeholder, 6, 10, 1);
          setFieldWidth_(els.quickEditPackSignField, els.quickEditPackNotationSign, els.quickEditPackNotationSign.value, "+", 7, 8, 0);
          setFieldWidth_(els.quickEditPackCountField, els.quickEditPackNotationCount, form.packNotationCount, "0", 6, 8, 1);
          scheduleQuickEditMeasuredLayout_();
        }

        function renderItemMarkup(item) {
